{
  "name": "lmthing",
  "version": "1.0.4",
  "type": "module",
  "bin": {
    "lmthing": "dist/bin.js",
    "lmt": "dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.web.ts && node scripts/embed-web.mjs && tsup",
    "build:web": "vite build --config vite.config.web.ts",
    "prepublishOnly": "pnpm build",
    "dev:web": "vite --config vite.config.web.ts",
    "preview:web": "vite preview --config vite.config.web.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/provider": "^3.0.8",
    "@modelcontextprotocol/sdk": "catalog:",
    "ai": "^6.0.86",
    "citty": "^0.1.0",
    "dotenv": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.0",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.60",
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/azure": "^3.0.30",
    "@ai-sdk/cohere": "^3.0.21",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/groq": "^3.0.24",
    "@ai-sdk/mistral": "^3.0.20",
    "@ai-sdk/openai": "^3.0.29"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@lmthing/repl": "workspace:*",
    "@radix-ui/themes": "^3.0.0",
    "@swc/core": "^1.10.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "shiki": "^1.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  }
}